{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AppSettings": {
    "FFmpeg": {
      "BinaryPath": "./ffmpeg-bin"
    },
    "Whisper": {
      "ApiKey": "",
      "Endpoint": "https://api.openai.com/v1/audio/transcriptions",
      "Model": "whisper-1"
    },
    "Claude": {
      "ApiKey": "",
      "Model": "claude-sonnet-4-6",
      "Endpoint": "https://api.anthropic.com/v1/messages"
    },
    "Storage": {
      "TempPath": "./temp-jobs",
      "MaxFileSizeBytes": 524288000,
      "JobTtlMinutes": 60
    },
    "Razorpay": {
      "KeyId": "",
      "KeySecret": ""
    }
  }
}
