{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AppSettings": {
    "FFmpeg": {
      "BinaryPath": "./ffmpeg-bin"
    },
    "Whisper": {
      "ApiKey": "",
      "Endpoint": "https://api.openai.com/v1/audio/transcriptions",
      "Model": "whisper-1"
    },
    "Claude": {
      "ApiKey": "",
      "Model": "claude-sonnet-4-6",
      "Endpoint": "https://api.anthropic.com/v1/messages"
    },
    "Storage": {
      "TempPath": "./temp-jobs",
      "MaxFileSizeBytes": 524288000,
      "JobTtlMinutes": 60
    },
    "Razorpay": {
      "KeyId": "",
      "KeySecret": ""
    },
    "Prediction": {
      "Low":    { "Min": 0.05, "Max": 0.20 },
      "Medium": { "Min": 0.20, "Max": 0.80 },
      "High":   { "Min": 0.50, "Max": 3.00 }
    },
    "FollowerTiers": {
      "Tiers":          [ 1000, 10000, 100000, 500000, 1000000 ],
      "ScalingFactors": [ 1.00,  0.65,   0.40,   0.32,    0.28 ]
    },
    "Instagram": {
      "AppId":           "",
      "AppSecret":       "",
      "RedirectUri":     "",
      "FrontendBaseUrl": "http://localhost:5173"
    },
    "ReelPlanLimits": {
      "Free":    1,
      "Starter": 3,
      "Creator": 5,
      "Pro":     5
    },
    "AutoReel": {
      "MaxReels":                5,
      "MinSegmentSeconds":       5.0,
      "MaxSegmentSeconds":       30.0,
      "SceneDetectionThreshold": 0.35,
      "OutputWidth":             720,
      "OutputHeight":            1280,
      "EnableZoom":              false,
      "EnableSubtitles":         false,
      "EnableAiTitles":          true,
      "OutputCrf":               28,
      "OutputPreset":            "ultrafast"
    },
    "Features": {
      "EnableDynamicReframe": false
    }
  }
}
